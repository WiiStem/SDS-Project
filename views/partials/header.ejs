<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %> | Lab SDS Library</title>
    <link rel="stylesheet" href="/css/styles.css" />
    <script defer src="/js/app.js"></script>
  </head>
  <body>
    <header class="site-header">
      <div class="brand-lockup">
        <a href="/sds" class="brand-mark">Lab SDS Library</a>
        <p>Searchable safety data sheets by lab, tag, and product.</p>
      </div>
      <nav class="top-nav">
        <a href="/sds">Browse SDS</a>
        <% if (isAdmin) { %>
          <a href="/admin/sds">Admin</a>
          <form action="/auth/logout" method="post">
            <button type="submit" class="link-button">Logout</button>
          </form>
        <% } else { %>
          <a href="/auth/microsoft">Microsoft Login</a>
        <% } %>
      </nav>
    </header>
    <main class="page-shell">
