    "dotenv": "^16.4.7",
    "ejs": "^3.1.10",
    "express": "^4.22.1",
    "express-session": "^1.18.1",
    "method-override": "^3.0.0",
    "multer": "^1.4.5-lts.1",
    "passport": "^0.7.0",
    "passport-microsoft": "^1.0.0",
    "pdf-lib": "^1.17.1",
    "prisma": "^6.6.0",
    "slugify": "^1.6.6",
    "zod": "^3.24.2"
  }
